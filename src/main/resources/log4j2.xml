<?xml version="1.0" encoding="utf-8"?>
<Configuration packages="pl.tkowalcz.tjahzi.log4j2">

    <Appenders>
        <RollingFile name="file" fileName="${sys:mule.home}${sys:file.separator}logs${sys:file.separator}hello-api.log"
                 filePattern="${sys:mule.home}${sys:file.separator}logs${sys:file.separator}hello-api-%i.log">
            <PatternLayout pattern="%-5p %d [%t] [processor: %X{processorPath}; event: %X{correlationId}] %c: %m%n"/>
            <SizeBasedTriggeringPolicy size="10 MB"/>
            <DefaultRolloverStrategy max="10"/>
        </RollingFile>

        <Loki name="LOKI">
            <url>https://logs-prod-028.grafana.net/loki/api/v1/push</url>

            <username>1667259</username>
            <password>glc_eyJvIjoiMTgzMDY0NCIsIm4iOiJtdWxlLWxva2ktcHVzaC1tdWxlc29mdCIsImsiOiJKZjg1dWtZNDgxbDhlWTRjTzVManJCOTMiLCJtIjp7InIiOiJ1cyJ9fQ==</password>

            <PatternLayout>
                <Pattern>%-5p %d [%t] %c: %m%n</Pattern>
            </PatternLayout>

            <Label name="app" value="demo-api"/>
            <Label name="env" value="cloudhub2"/>
            <LogLevelLabel>log_level</LogLevelLabel>
        </Loki>
    </Appenders>

    <Loggers>
        <AsyncLogger name="org.mule.service.http" level="WARN"/>
        <AsyncLogger name="org.mule.extension.http" level="WARN"/>
        <AsyncLogger name="org.mule.runtime.core.internal.processor.LoggerMessageProcessor" level="INFO"/>

        <AsyncRoot level="INFO">
            <AppenderRef ref="file"/>
        </AsyncRoot>
        <AsyncLogger name="LOKI" level="INFO" additivity="false">
            <AppenderRef ref="LOKI"/>
        </AsyncLogger>
    </Loggers>

</Configuration>
